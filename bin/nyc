use v5.36;
use feature qw( try );
no warnings 'experimental::try';

use utf8;
use open qw(:std :encoding(UTF-8));

use POSIX qw(strftime);
use Getopt::Long ();
use Pod::Usage;
use File::Basename qw(dirname basename);
use File::Copy qw(move);
use File::Path qw(make_path remove_tree);
use File::Spec;
use Cwd qw(abs_path);
use JSON::PP ();
use File::Find qw(find);
use Unicode::Normalize qw(NFD);
use version;

our $VERSION = version->declare('v2.0.0');
my $JSON = JSON::PP->new
  ->ascii(0)
  ->canonical(1)
  ->allow_nonref(1)
  ->utf8(0);

my @PROTECTED_PATHS = map { File::Spec->canonpath($_) } qw(
  node_modules
  src/public
  _config.ts
  deno.json
  src/_includes
  src/_data.yml
  src/components
  src/privacy-policy
  src/index.page.tsx
);

my %CONTENT_TYPES = (
  post => {
    dir    => [ 'src', 'posts' ],
    layout => 'layouts/post.tsx',
  },
  page => {
    dir    => ['src'],
    layout => 'layout.tsx',
    image  => '/img/urutau.png',
  },
);

my @FRONTMATTER_ORDER = qw(
  title
  description
  date
  author
  image
  draft
  tags
  layout
  slug
  section
  lastmod
);

use Readonly;

Readonly::Scalar my $DEFAULT_AUTHOR      => 'FuncProgLinux';
Readonly::Scalar my $DEFAULT_DESCRIPTION => 'Este artículo está en redacción temprana.';
Readonly::Scalar my $DEFAULT_TRASH_DIR   => '.nyc-trash';

exit main(@ARGV);

sub main (@argv) {
  my ($opts, $command, $cmd_args) = parse_global_cli(@argv);

  if ($opts->{help}) {
    if (my $section = $opts->{help_section}) {
      pod2usage(-sections => $section, -exitval => 0);
    }
    pod2usage(-verbose => 2, -exitval => 0);
  }

  unless ($command) {
    pod2usage(-verbose => 1, -exitval => 1);
  }

  my $env = build_environment($opts->{root});
  $opts->{env} = $env;

  my %dispatch = (
    add     => \&cmd_add,
    doctor  => \&cmd_doctor,
    rm      => \&cmd_rm,
    list    => \&cmd_list,
    draft   => \&cmd_draft,
    publish => \&cmd_publish,
    info    => \&cmd_info,
  );

  my $handler = $dispatch{$command}
    or die "Unknown command '$command'.";

  my $exit_code = 1;
  try {
    $exit_code = $handler->($cmd_args, $opts);
  } catch ($err) {
    chomp $err;
    plog("Error: $err");
    $exit_code = 1;
  }

  return $exit_code;
}

sub parse_global_cli (@argv) {
  my @raw = @argv;
  my %opts = (
    dry_run => 0,
    verbose => 0,
    yes     => 0,
    root    => '.',
  );

  my $parser = Getopt::Long::Parser->new(
    config => [qw(bundling no_ignore_case pass_through)],
  );

  $parser->getoptionsfromarray(
    \@argv,
    'help|h'    => \$opts{help},
    'verbose|v' => \$opts{verbose},
    'dry-run|d' => \$opts{dry_run},
    'root|r=s'  => \$opts{root},
    'yes|y|force' => \$opts{yes},
  ) or pod2usage(2);

  my $command = shift @argv;
  if ($opts{help}) {
    $opts{help_section} = extract_subcommand_help_section(\@raw, $command);
  }

  return (\%opts, $command, \@argv);
}

sub extract_subcommand_help_section ($raw, $command) {
  return unless defined $command;
  my $seen = 0;
  for my $token (@$raw) {
    if (!$seen) {
      $seen = 1 if $token eq $command;
      next;
    }
    return $command if is_help_token($token);
  }
  return;
}

sub is_help_token ($token) {
  return 0 unless defined $token;
  return ($token eq '--help' || $token eq '-h' || $token eq '-?');
}

sub build_environment ($root) {
  my $abs_root = abs_path($root)
    or die "Unable to resolve project root '$root'.";

  return {
    root      => $abs_root,
    trash_dir => File::Spec->catdir($abs_root, $DEFAULT_TRASH_DIR),
  };
}

sub cmd_add ($argv, $opts) {
  my %params = (
    type        => undef,
    title       => undef,
    description => $DEFAULT_DESCRIPTION,
    date        => undef,
    author      => $DEFAULT_AUTHOR,
    draft       => 1,
    tags        => [],
    slug        => undef,
    section     => undef,
    layout      => undef,
    image       => undef,
  );

  my @tag_opts;
  my $parser = Getopt::Long::Parser->new(config => [qw(bundling no_ignore_case)]);
  $parser->getoptionsfromarray(
    $argv,
    'type|t=s'        => \$params{type},
    'title|T=s'       => \$params{title},
    'description|desc=s' => \$params{description},
    'date=s'          => \$params{date},
    'author=s'        => \$params{author},
    'slug=s'          => \$params{slug},
    'tag=s@'          => \@tag_opts,
    'tags=s'          => \@tag_opts,
    'draft!'          => \$params{draft},
    'section=s'       => \$params{section},
    'layout=s'        => \$params{layout},
    'image=s'         => \$params{image},
  ) or die "Invalid options for add.";

  $params{tags} = parse_tag_args(@tag_opts);

  my @positional = @$argv;
  $params{type} //= shift @positional if @positional;
  $params{type} //= 'post';
  $params{title} //= join(' ', @positional);

  die "Missing content type for add."
    unless exists $CONTENT_TYPES{ $params{type} };
  die "Missing title for add." unless defined $params{title} && length $params{title};

  my $content_spec = $CONTENT_TYPES{ $params{type} };
  my $slug  = $params{slug} // get_slug($params{title});
  my $date  = $params{date} // strftime('%Y-%m-%d', localtime);
  my $layout = $params{layout} // $content_spec->{layout};
  my @section_parts = normalize_section($params{section});
  my $image  = $params{image} // default_image_for($params{type}, $content_spec, $slug, \@section_parts);

  die "Unable to derive slug." unless length $slug;

  my $relative_dir = File::Spec->catdir(@{ $content_spec->{dir} }, @section_parts);
  my $filename     = "$slug.md";
  my $relative_path = File::Spec->catfile($relative_dir, $filename);
  my ($target_path, $rel_path) = resolve_and_guard($opts->{env}, $relative_path);

  die "File already exists at '$rel_path'." if -e $target_path;
  die "Path '$rel_path' is protected." if is_protected_path($rel_path);

  verbose_log($opts, "Creating '$rel_path'.");

  my $frontmatter = {
    title       => $params{title},
    description => $params{description},
    date        => $date,
    author      => $params{author},
    image       => $image,
    draft       => $params{draft} ? 'true' : 'false',
    tags        => $params{tags},
    layout      => $layout,
    slug        => $slug,
  };

  $frontmatter->{section} = join('/', @section_parts) if @section_parts;

  my $body = sprintf("# %s\n\n", $params{title});

  if ($opts->{dry_run}) {
    plog("Dry-Run: Would create '$rel_path'.");
    plog(serialize_frontmatter($frontmatter));
  } else {
    make_path(dirname($target_path)) unless -d dirname($target_path);
    write_markdown_file($target_path, $frontmatter, $body);
    plog("Created '$rel_path'.");
  }

  return 0;
}

sub cmd_rm ($argv, $opts) {
  my %params = (
    permanent => 0,
    trash     => undef,
  );

  my $parser = Getopt::Long::Parser->new(config => [qw(bundling no_ignore_case)]);
  $parser->getoptionsfromarray(
    $argv,
    'permanent'   => \$params{permanent},
    'trash-dir=s' => \$params{trash},
  ) or die "Invalid options for rm.";

  my $path = shift @$argv // die "Missing path for rm.";
  my ($abs_path, $rel_path) = resolve_and_guard($opts->{env}, $path);

  die "No such file or directory '$rel_path'." unless -e $abs_path;
  die "'$rel_path' is protected and cannot be removed."
    if is_protected_path($rel_path);

  if ($opts->{dry_run}) {
    plog("Dry-Run: Would remove '$rel_path'.");
    return 0;
  }

  my $action = $params{permanent} ? 'permanently delete' : 'move to trash';
  return 0 unless confirm_action($opts, "Confirm to $action '$rel_path'?");

  if ($params{permanent}) {
    remove_path($abs_path, $rel_path);
    plog("Removed '$rel_path'.");
  } else {
    my $trash_dir = defined $params{trash}
      ? File::Spec->rel2abs($params{trash}, $opts->{env}{root})
      : $opts->{env}{trash_dir};
    make_path($trash_dir) unless -d $trash_dir;
    my $timestamp = strftime('%Y%m%d_%H%M%S', localtime);
    my $dest = File::Spec->catfile(
      $trash_dir,
      sprintf('%s.%s', basename($rel_path), $timestamp),
    );
    move($abs_path, $dest)
      or die "Unable to move '$rel_path' to trash: $!";
    plog("Moved '$rel_path' to trash at '$dest'.");
  }

  return 0;
}

sub cmd_doctor ($argv, $opts) {
  my %params = (
    json => 0,
  );

  my $parser = Getopt::Long::Parser->new(config => [qw(bundling no_ignore_case)]);
  $parser->getoptionsfromarray(
    $argv,
    'json' => \$params{json},
  ) or die "Invalid options for doctor.";

  my @issues;
  my %authors_by_url;
  my %tags_by_url;
  my $scan_dir = File::Spec->catdir($opts->{env}{root}, 'src');

  find(
    {
      wanted => sub {
        return unless -f $_;
        return unless $_ =~ /\.md$/i;

        my $abs = $File::Find::name;
        my $rel = File::Spec->canonpath(
          File::Spec->abs2rel($abs, $opts->{env}{root}),
        );

        my ($meta, $body);
        eval {
          ($meta, $body) = read_markdown_file($abs);
          1;
        } or do {
          push @issues, doctor_issue(
            'error',
            $rel,
            $@ =~ s/\n+\z//r,
            'frontmatter',
          );
          return;
        };

        push @issues, validate_entry($opts, $rel, $meta, $body);

        if (index($rel, 'src/posts/') == 0) {
          for my $tag (@{ $meta->{tags} // [] }) {
            push @{ $tags_by_url{ tag_url_for($tag) } }, {
              path  => $rel,
              value => $tag,
            };
          }

          if (defined $meta->{author} && $meta->{author} ne q{}) {
            push @{ $authors_by_url{ author_url_for($meta->{author}) } }, {
              path  => $rel,
              value => $meta->{author},
            };
          }
        }
      },
      no_chdir => 1,
    },
    $scan_dir,
  );

  push @issues, detect_taxonomy_collisions('tag', \%tags_by_url);
  push @issues, detect_taxonomy_collisions('author', \%authors_by_url);

  if ($params{json}) {
    say $JSON->encode(\@issues);
  } elsif (!@issues) {
    plog('Doctor: no problems found.');
  } else {
    for my $issue (@issues) {
      plog(
        sprintf(
          '%s [%s] %s: %s',
          uc($issue->{level}),
          $issue->{code},
          $issue->{path},
          $issue->{message},
        ),
      );
    }

    my $errors = grep { $_->{level} eq 'error' } @issues;
    my $warnings = grep { $_->{level} eq 'warning' } @issues;
    plog("Doctor summary: $errors error(s), $warnings warning(s).");
  }

  my $error_count = grep { $_->{level} eq 'error' } @issues;
  return $error_count ? 1 : 0;
}

sub cmd_list ($argv, $opts) {
  my %params = (
    type      => 'post',
    format    => 'table',
    section   => undef,
    limit     => undef,
    drafts    => 0,
    published => 0,
  );

  my $parser = Getopt::Long::Parser->new(config => [qw(bundling no_ignore_case)]);
  $parser->getoptionsfromarray(
    $argv,
    'type|t=s'    => \$params{type},
    'format=s'    => \$params{format},
    'section=s'   => \$params{section},
    'limit=i'     => \$params{limit},
    'drafts'      => \$params{drafts},
    'published'   => \$params{published},
  ) or die "Invalid options for list.";

  my @types =
    $params{type} eq 'all'
    ? sort keys %CONTENT_TYPES
    : ($params{type});

  for my $type (@types) {
    die "Unknown content type '$type'."
      unless exists $CONTENT_TYPES{$type};
  }

  my @entries;
  for my $type (@types) {
    push @entries, @{ gather_entries_for_type($type, \%params, $opts) };
  }

  if ($params{drafts}) {
    @entries = grep { is_truthy($_->{draft}) } @entries;
  } elsif ($params{published}) {
    @entries = grep { !is_truthy($_->{draft}) } @entries;
  }

  @entries = sort {
    ($b->{date} // '') cmp ($a->{date} // '')
      || $a->{path} cmp $b->{path}
  } @entries;

  if (defined $params{limit} && $params{limit} > 0 && @entries > $params{limit}) {
    @entries = @entries[ 0 .. ($params{limit} - 1) ];
  }

  if ($params{format} eq 'json') {
    say $JSON->encode(\@entries);
  } else {
    printf "%-8s %-10s %-12s %-40s %s\n",
      'TYPE', 'STATUS', 'DATE', 'TITLE', 'PATH';
    for my $entry (@entries) {
      printf "%-8s %-10s %-12s %-40s %s\n",
        $entry->{type},
        is_truthy($entry->{draft}) ? 'draft' : 'published',
        $entry->{date} // '',
        truncate_string($entry->{title} // '', 38),
        $entry->{path};
    }
  }

  return 0;
}

sub cmd_info ($argv, $opts) {
  my %params = ( json => 0 );

  my $parser = Getopt::Long::Parser->new(config => [qw(bundling no_ignore_case)]);
  $parser->getoptionsfromarray(
    $argv,
    'json' => \$params{json},
  ) or die "Invalid options for info.";

  my $path = shift @$argv // die "Missing path for info.";
  my ($abs_path, $rel_path) = resolve_and_guard($opts->{env}, $path);
  die "No such file '$rel_path'." unless -e $abs_path;

  my ($meta, $body) = read_markdown_file($abs_path);
  my $info = {
    path     => $rel_path,
    metadata => $meta,
    words    => count_words($body),
    bytes    => -s $abs_path,
  };

  if ($params{json}) {
    say $JSON->encode($info);
  } else {
    plog("Path: $rel_path");
    for my $key (sort keys %{ $info->{metadata} }) {
      my $value = $info->{metadata}{$key};
      if (ref $value eq 'ARRAY') {
        plog(sprintf('%s: %s', ucfirst($key), join(', ', @{ $value })));
      } else {
        plog(sprintf('%s: %s', ucfirst($key), defined $value ? $value : ''));
      }
    }
    plog("Words: $info->{words}");
    plog("Bytes: $info->{bytes}");
  }

  return 0;
}

sub cmd_draft ($argv, $opts) {
  return cmd_set_draft_flag($argv, $opts, 1);
}

sub cmd_publish ($argv, $opts) {
  return cmd_set_draft_flag($argv, $opts, 0);
}

sub cmd_set_draft_flag ($argv, $opts, $value) {
  my $path = shift @$argv // die "Missing path.";

  return update_markdown_file($path, $opts, sub ($meta, $body, $rel_path) {
    my $current = is_truthy($meta->{draft}) ? 1 : 0;
    my $target  = $value ? 1 : 0;
    return 0 if $current == $target;
    $meta->{draft}  = $target ? 'true' : 'false';
    $meta->{lastmod} = strftime('%Y-%m-%d', localtime);
    return 1;
  });
}

sub gather_entries_for_type ($type, $params, $opts) {
  my $spec = $CONTENT_TYPES{$type};
  my @section_parts = normalize_section($params->{section});
  my $relative_root = File::Spec->catdir(@{ $spec->{dir} }, @section_parts);
  my $scan_dir = File::Spec->catdir($opts->{env}{root}, $relative_root);
  return [] unless -d $scan_dir;

  my @entries;
  find(
    {
      wanted => sub {
        return unless -f $_;
        return unless $_ =~ /\.md$/i;
        my $abs = $File::Find::name;
        my $rel = File::Spec->abs2rel($abs, $opts->{env}{root});
        my $data = eval { [ read_markdown_file($abs) ] };
        if (!$data) {
          verbose_log($opts, "Skipping '$rel': $@" );
          return;
        }
        my ($meta, undef) = @$data;
        my $date = $meta->{date} // format_timestamp( (stat($abs))[9] );
        push @entries, {
          type  => $type,
          path  => $rel,
          title => $meta->{title} // basename($abs),
          date  => $date,
          draft => $meta->{draft} // 'false',
          tags  => $meta->{tags} // [],
        };
      },
      no_chdir => 1,
    },
    $scan_dir,
  );

  return \@entries;
}

sub validate_entry ($opts, $path, $meta, $body) {
  my @issues;
  my $is_post = index($path, 'src/posts/') == 0;

  push @issues, doctor_issue('error', $path, "Missing 'title' front matter.", 'missing_title')
    unless defined $meta->{title} && $meta->{title} ne q{};

  if ($is_post) {
    push @issues, doctor_issue('error', $path, "Missing 'date' front matter.", 'missing_date')
      unless defined $meta->{date} && $meta->{date} ne q{};

    if (defined $meta->{date} && $meta->{date} !~ /\A\d{4}-\d{2}-\d{2}\z/) {
      push @issues, doctor_issue(
        'error',
        $path,
        "Date '$meta->{date}' must use YYYY-MM-DD format.",
        'invalid_date',
      );
    }
  }

  if (defined $meta->{layout} && $meta->{layout} ne q{}) {
    my $layout_abs = File::Spec->canonpath(
      File::Spec->catfile(
        $opts->{env}{root},
        'src',
        '_includes',
        split(m{/}, $meta->{layout}),
      ),
    );

    if (!-f $layout_abs) {
      push @issues, doctor_issue(
        'error',
        $path,
        "Layout '$meta->{layout}' does not exist under src/_includes/.",
        'missing_layout',
      );
    }
  }

  if (!$is_post && defined $meta->{image} && $meta->{image} =~ m{/@/}) {
    push @issues, doctor_issue(
      'error',
      $path,
      "Non-post pages must not use the '/@/' OpenGraph placeholder.",
      'invalid_page_image',
    );
  }

  push @issues, detect_public_emails($path, $meta, $body);
  return @issues;
}

sub detect_public_emails ($path, $meta, $body) {
  my @issues;
  my %seen;
  my @haystacks = ($body // q{});

  for my $key (keys %$meta) {
    my $value = $meta->{$key};
    if (ref $value eq 'ARRAY') {
      push @haystacks, @$value;
    } elsif (defined $value) {
      push @haystacks, $value;
    }
  }

  for my $value (@haystacks) {
    while ($value =~ /([A-Z0-9._%+\-]+@[A-Z0-9.\-]+\.[A-Z]{2,})/ig) {
      my $email = $1;
      next if $seen{lc $email}++;
      next if $email =~ /\A(?:example|user|name|test)\@/i;
      next if $email =~ /\@(example|email)\.(?:com|org|net)\z/i;

      push @issues, doctor_issue(
        'warning',
        $path,
        "Possible public e-mail address detected: <$email>.",
        'public_email',
      );
    }
  }

  return @issues;
}

sub detect_taxonomy_collisions ($kind, $groups) {
  my @issues;

  for my $url (sort keys %$groups) {
    my %labels = map { lc($_->{value}) => $_->{value} } @{ $groups->{$url} };
    next if scalar(keys %labels) < 2;

    my @values = sort values %labels;
    my %paths = map { $_->{path} => 1 } @{ $groups->{$url} };

    for my $path (sort keys %paths) {
      push @issues, doctor_issue(
        'error',
        $path,
        sprintf(
          "The %s values [%s] collapse to the same output path '%s'.",
          $kind,
          join(', ', @values),
          $url,
        ),
        "duplicate_${kind}_url",
      );
    }
  }

  return @issues;
}

sub doctor_issue ($level, $path, $message, $code = 'general') {
  return {
    code    => $code,
    level   => $level,
    message => $message,
    path    => $path,
  };
}

sub resolve_and_guard ($env, $path) {
  die 'Missing path.' unless defined $path && length $path;
  my $abs = File::Spec->rel2abs($path, $env->{root});
  $abs = File::Spec->canonpath($abs);
  my $root = $env->{root};
  my $prefix = $root;
  $prefix .= '/' unless $prefix =~ m{/$};
  if ($abs ne $root && index($abs, $prefix) != 0) {
    die "Path '$path' escapes workspace root.";
  }
  my $rel = File::Spec->abs2rel($abs, $root);
  return ($abs, File::Spec->canonpath($rel));
}

sub is_protected_path ($rel_path) {
  my $normalized = File::Spec->canonpath($rel_path // '');
  return 1 if $normalized =~ /\.\./;
  for my $protected (@PROTECTED_PATHS) {
    return 1 if $normalized eq $protected;
    return 1 if index($normalized, "$protected/") == 0;
  }
  return 0;
}

sub remove_path ($abs_path, $rel_path) {
  if (-d $abs_path) {
    my $errors = [];
    remove_tree($abs_path, { error => $errors });
    if (@$errors) {
      my $msg = join '; ', map {
        my $where = $_->{file} // $_->{path} // $rel_path;
        sprintf('%s: %s', $where, $_->{message});
      } @$errors;
      die "Failed to remove '$rel_path': $msg";
    }
  } else {
    unlink $abs_path or die "Failed to remove '$rel_path': $!";
  }
}

sub confirm_action ($opts, $message) {
  return 1 if $opts->{yes};
  print "$message (y/N): ";
  my $answer = <STDIN>;
  return defined $answer && $answer =~ /^[Yy]/;
}

sub plog ($msg) {
  my $timestamp = strftime('%Y-%m-%d %H:%M:%S', localtime);
  say "[NYC] - [$timestamp]: $msg";
}

sub verbose_log ($opts, $msg) {
  plog($msg) if $opts->{verbose};
}

sub get_slug ($title) {
  my $slug = lc $title;
  $slug =~ s/[^a-z0-9\s-]+//g;
  $slug =~ s/\s+/-/g;
  $slug =~ s/-+/-/g;
  $slug =~ s/^-+//;
  $slug =~ s/-+$//;
  return $slug;
}

sub normalize_taxonomy_value ($value) {
  my $normalized = NFD(lc($value // q{}));
  $normalized =~ s/\pM+//g;
  $normalized =~ s/^\s+//;
  $normalized =~ s/\s+$//;
  $normalized =~ s/[^a-z0-9\s-]+//g;
  $normalized =~ s/\s+/-/g;
  $normalized =~ s/-+/-/g;
  $normalized =~ s/^-+//;
  $normalized =~ s/-+$//;
  return $normalized;
}

sub tag_url_for ($tag) {
  return '/tags/' . normalize_taxonomy_value($tag) . '/';
}

sub author_url_for ($author) {
  return '/author/' . normalize_taxonomy_value($author) . '/';
}

sub default_image_for ($type, $spec, $slug, $section_parts) {
  if ($type eq 'post') {
    return '/' . join('/', 'posts', @$section_parts, $slug, 'index.png');
  }

  return $spec->{image};
}

sub normalize_section ($section) {
  return () unless defined $section && length $section;
  my @parts = grep { length } split m{/+}, $section;
  return map { get_slug($_) } @parts;
}

sub parse_tag_args (@args) {
  my %seen;
  my @tags;
  for my $entry (@args) {
    next unless defined $entry;
    my @candidates = split /,/, $entry;
    for my $tag (@candidates) {
      $tag =~ s/^\s+//;
      $tag =~ s/\s+$//;
      next unless length $tag;
      push @tags, $tag unless $seen{ lc $tag }++;
    }
  }
  return \@tags;
}

sub read_markdown_file ($path) {
  open my $fh, '<', $path or die "Unable to read '$path': $!";
  local $/ = undef;
  my $raw = <$fh> // '';
  close $fh;

  if ($raw !~ /^---\s*\n(.*?)\n---\s*\n?(.*)\z/s) {
    die "File '$path' is missing YAML frontmatter.";
  }

  my ($front, $body) = ($1, $2);
  my $meta = parse_frontmatter($front);
  return ($meta, $body);
}

sub write_markdown_file ($path, $meta, $body) {
  my $front = serialize_frontmatter($meta);
  open my $fh, '>', $path or die "Unable to write '$path': $!";
  print {$fh} $front;
  print {$fh} $body if defined $body;
  close $fh;
}

sub serialize_frontmatter ($meta) {
  my @lines = ('---');
  my %copy = %$meta;

  for my $key (@FRONTMATTER_ORDER) {
    next unless exists $copy{$key};
    push @lines, @{ format_meta_lines($key, delete $copy{$key}) };
  }

  for my $key (sort keys %copy) {
    push @lines, @{ format_meta_lines($key, $copy{$key}) };
  }

  push @lines, '---', '';
  return join("\n", @lines);
}

sub format_meta_lines ($key, $value) {
  if (ref $value eq 'ARRAY') {
    return [ "$key: []" ] unless @$value;
    return [ "$key:", map { '  - ' . yaml_scalar($_) } @$value ];
  }
  return [ sprintf('%s: %s', $key, yaml_scalar($value)) ];
}

sub yaml_scalar ($value) {
  return '""' unless defined $value && length $value;
  my $lc = lc $value;
  return 'true'  if $lc eq 'true';
  return 'false' if $lc eq 'false';
  my $escaped = $value;
  $escaped =~ s/"/\\"/g;
  return '"' . $escaped . '"';
}

sub parse_frontmatter ($front_text) {
  my %meta;
  my $current_key;

  for my $line (split /\n/, $front_text) {
    $line =~ s/\r$//;
    next if $line =~ /^\s*#/;
    if ($line =~ /^\s*([A-Za-z0-9_]+)\s*:\s*(.*)$/) {
      my ($key, $value) = ($1, $2 // '');
      if ($value eq '[]') {
        $meta{$key} = [];
        $current_key = undef;
        next;
      }
      if ($value =~ /\S/) {
        $meta{$key} = parse_front_value($value);
        $current_key = undef;
      } else {
        $meta{$key} = [];
        $current_key = $key;
      }
    } elsif ($line =~ /^\s*-\s*(.+)$/ && defined $current_key) {
      push @{ $meta{$current_key} }, parse_front_value($1);
    }
  }

  return \%meta;
}

sub parse_front_value ($value) {
  $value =~ s/^\s+//;
  $value =~ s/\s+$//;
  if ($value =~ /^"(.*)"$/) {
    ($value = $1) =~ s/\\"/"/g;
  } elsif ($value =~ /^'(.*)'$/) {
    ($value = $1) =~ s/\\'/'/g;
  }
  my $lc = lc $value;
  return 'true'  if $lc eq 'true';
  return 'false' if $lc eq 'false';
  return $value;
}

sub update_markdown_file ($path, $opts, $mutator) {
  my ($abs_path, $rel_path) = resolve_and_guard($opts->{env}, $path);
  die "No such file '$rel_path'." unless -f $abs_path;
  die "'$rel_path' is protected." if is_protected_path($rel_path);

  my ($meta, $body) = read_markdown_file($abs_path);
  my $changed = $mutator->($meta, $body, $rel_path) ? 1 : 0;
  unless ($changed) {
    plog("No changes required for '$rel_path'.");
    return 0;
  }

  if ($opts->{dry_run}) {
    plog("Dry-Run: Would update '$rel_path'.");
    return 0;
  }

  write_markdown_file($abs_path, $meta, $body);
  plog("Updated '$rel_path'.");
  return 0;
}

sub truncate_string ($value, $width) {
  $value //= '';
  return $value if length($value) <= $width;
  my $ellipsis = '...';
  return substr($value, 0, $width) if $width <= length $ellipsis;
  return substr($value, 0, $width - length $ellipsis) . $ellipsis;
}

sub count_words ($text) {
  return 0 unless defined $text;
  my @words = ($text =~ /\b[^\s]+\b/g);
  return scalar @words;
}

sub format_timestamp ($epoch) {
  return '' unless defined $epoch;
  return strftime('%Y-%m-%d', localtime $epoch);
}

sub is_truthy ($value) {
  return 0 unless defined $value;
  return $value =~ /^(?:1|true|yes)$/i ? 1 : 0;
}

__END__

=encoding utf8

=head1 NAME

nyc - Small Perl helper inspired by the Hugo CLI.

=head1 SYNOPSIS

B<nyc> [OPTIONS] I<COMMAND> [ARGS]

=head1 OPTIONS

=over 8

=item B<-h, --help>

Show this help screen.

=item B<-v, --verbose>

Print verbose log messages during execution.

=item B<-d, --dry-run>

Show what would be done without mutating the project tree.

=item B<-r, --root PATH>

Run nyc targeting another root directory. Defaults to the current working directory.

=item B<-y, --yes>

Answer "yes" to confirmation prompts automatically (also available as C<--force>).

=back

=head1 COMMANDS

=head2 add

Create a new Markdown node with pre-populated front matter.

Usage: B<nyc add> [OPTIONS] [type] [title]

Options:

=over 4

=item B<--type>, B<-t>

Content type (C<post> or C<page>). Defaults to C<post>.

=item B<--title>, B<-T>

Explicit title. If omitted nyc uses the remaining positional arguments.

=item B<--slug>

Override the generated slug / filename.

=item B<--date>

Front matter date (defaults to today).

=item B<--description>, B<--author>, B<--layout>, B<--image>

Override the default metadata values.

=item B<--section>

Create the entry inside a nested section (e.g. C<guides/perl>).

=item B<--tag>, B<--tags>

Add tags. Repeat the flag or use comma separated values.

=item B<--draft!>

Mark the new content as a draft (enabled by default). Use C<--no-draft> to create a published post.

=back

=head2 rm

Delete files or directories with a reversible trash bin.

Usage: B<nyc rm> [--permanent] [--trash-dir DIR] PATH

=head2 doctor

Validate Markdown content, taxonomy URLs, front matter, and common publishing mistakes.

Usage: B<nyc doctor> [--json]

=head2 list

List blog entries (posts or pages) in a tabular or JSON format.

Usage: B<nyc list> [--type TYPE|all] [--section SECTION] [--drafts|--published] [--limit N] [--format table|json]

=head2 draft / publish

Toggle the draft flag in the front matter of an entry.

Usage: B<nyc draft> PATH

Usage: B<nyc publish> PATH

=head2 info

Show metadata and statistics for a Markdown file.

Usage: B<nyc info> [--json] PATH

=head1 DESCRIPTION

nyc is a Perl CLI that mimics a subset of Hugo's CLI commands while
remaining small enough to ship inside this repository. It can scaffold
new posts, inspect metadata, list drafts, and toggle publication state without
touching other parts of the project.

However, this tool is made SPECIFICALLY for this webpage source code, using it
outside the repository or inside your own Lume projects is heavily discouraged.

=head1 INTERNALS

I wasn't able to find an "official" way to do Perl docstrings and I don't
really believe heredocs are the answer to this particular problem. This section
covers the documentation for the internal subroutines used inside this program.

Mind you, this hardly counts as extensive documentation but it should give some
context in case you want to learn how to write Perl CLIs, modify this one or
even port it to another language. Although, if you are looking for a more
complete solution, I recommend checking out Hugo itself or even better,
contribute to the Lume CLI directly if it's within your possibilities.

=over 4

=item B<parse_global_cli>

Normalizes shared CLI flags early so subcommands only worry about their domain concerns.

=item B<extract_subcommand_help_section>

Figures out whether help was asked for a specific verb so docs stay
focused instead of overwhelming the user with the complete documentation POD
of this tool.

=item B<is_help_token>

Treats the many spellings of "help" the same. Or at least it tries to. I really
didn't do much testing whatsoever.

=item B<build_environment>

Resolves project boundaries up front so file operations never wander
outside the intended file tree. This comes with no warranty inside the guix
shell as I think it can mutate other directories if shared by mistake.

=item B<cmd_add>

Bootstraps new content with curated defaults. By curated I mean opinionated
and specifically for this website project.

=item B<cmd_rm>

Provides reversible cleanup so experimentation feels safe even when deleting whole trees.

=item B<cmd_list>

Curates a manifest of entries so you never imagine if all you know are
what you're told to care about.

...but after all this time you find your faith has faded...

=item B<cmd_info>

Gives a quick health check for any Markdown node without opening an editor.

=item B<cmd_draft>

Allows the editor/writer to mark work-in-progress posts without remembering
exact front matter values.

=item B<cmd_publish>

Graduates draft content via the same guard rails to avoid drift between states.

=item B<cmd_set_draft_flag>

Centralizes the draft toggle logic so both verbs stay consistent and timestamp updates happen in one place.

=item B<gather_entries_for_type>

Walks the content tree to provide higher-level commands with a reliable catalog of files.

=item B<resolve_and_guard>

Guarantees that every requested path stays under the workspace root before any IO occurs.

=item B<is_protected_path>

Shields critical directories and config files from accidental edits or deletions.

=item B<remove_path>

Encapsulates destructive actions so they respect trash bins and report failures clearly.

=item B<confirm_action>

Introduces an intentional pause before risky changes unless the caller explicitly bypasses it.

=item B<plog>

Emits timestamped messages so logs can be audited later.

=item B<verbose_log>

Keeps the default output calm while still giving curious users more insight on demand.

=item B<get_slug>

Transforms titles into predictable filenames, keeping URLs human-friendly.

=item B<normalize_section>

Ensures nested sections share the same slug rules so directory layouts stay tidy.

=item B<parse_tag_args>

Deduplicates tag inputs coming from multiple CLI flags to avoid noisy metadata.

=item B<read_markdown_file>

Parses front matter once so the rest of the tool can operate on structured data
instead of ad-hoc regexes. (Whatever that means)

=item B<write_markdown_file>

Writes Markdown and YAML in a stable order so diffs highlight meaningful changes.

=item B<serialize_frontmatter>

Preserves preferred field ordering to keep generated files approachable for editors.

=item B<format_meta_lines>

Keeps YAML formatting uniform across scalars and arrays for easier reviews.

=item B<yaml_scalar>

Quotes or unquotes metadata so YAML stays valid without becoming noisy.

=item B<parse_frontmatter>

Translates the YAML header back into Perl structures so commands can reason
about metadata safely.

=item B<parse_front_value>

Normalizes individual YAML values (especially booleans) to minimize surprises later.

=item B<update_markdown_file>

Wraps read/modify/write operations so guard rails like dry-run and
protected paths get enforced automatically.

=item B<truncate_string>

Keeps table output readable on narrower terminals by clipping long titles gracefully.

=item B<count_words>

Provides a fast approximation of article length for triaging writing effort.

=item B<format_timestamp>

Backfills missing dates with filesystem metadata so listings remain sortable.

=item B<is_truthy>

Interprets assorted YAML truthy values consistently for draft toggles and filters.

=back

